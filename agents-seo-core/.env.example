# Copy this to .env and fill in your values

# --- Local Ollama (light model, always on your laptop) ---
OLLAMA_URL=http://localhost:11434
LOCAL_LIGHT_MODEL=gemma4:e2b

# --- Remote vLLM (heavy models on GPU server via tunnel) ---
# Run the Jupyter cell below to get this URL, then paste it here.
# Leave blank to fall back to Ollama for all roles.
VLLM_URL=

# Model names as served by vLLM on the remote server
LOCAL_HEAVY_MODEL=google/gemma-4-27b-it
LOCAL_MID_MODEL=Qwen/Qwen3-14B

# --- Fireworks (optional cloud fallback for content_signal + report_writer) ---
FIREWORKS_KEY=

# --- Dry-run mode (set to 1 to skip all Fireworks calls) ---
LOCAL_ONLY=0

# --- API port ---
API_PORT=8080
