# ─────────────────────────────────────────────────────────────
# Findable — environment configuration
# Copy to `.env` and fill in the values:   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# --- App / HTTP server (api service) ---
APP_NAME=Findable
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
LOG_LEVEL=info
CORS_ORIGINS=*

# --- Firecrawl (rendered crawl) ---
# Get a key at https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-your-key-here
FIRECRAWL_API_URL=https://api.firecrawl.dev
FIRECRAWL_API_VERSION=v2
FIRECRAWL_TIMEOUT=60

# --- Direct fetch (raw HTML, robots.txt, sitemap.xml, llms.txt) ---
FETCH_TIMEOUT=20
FETCH_USER_AGENT=FindableBot/0.1 (+https://findable.ai)

# --- Redis cache ---
# In docker-compose this is overridden to redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=604800          # 0 = never expire

# --- Orchestrator scope ---
MAX_DEEP_PAGES=4
MAX_SHALLOW_PAGES=50

# ─────────────────────────────────────────────────────────────
# Agents SEO Core (agents-api service — inference layer)
# ─────────────────────────────────────────────────────────────

# Port the agents-api container exposes on the host
API_PORT=8080

# --- Local Ollama (light model, runs on your laptop) ---
# Docker uses host.docker.internal to reach Ollama on the host machine.
OLLAMA_URL=http://host.docker.internal:11434
LOCAL_LIGHT_MODEL=gemma4:e2b

# --- Remote vLLM (heavy models on GPU server via ngrok/cloudflared tunnel) ---
# Run jupyter_vllm_setup.py on your GPU server to get this URL.
# Leave blank to fall back to Ollama for all roles.
VLLM_URL=
LOCAL_HEAVY_MODEL=google/gemma-4-27b-it
LOCAL_MID_MODEL=Qwen/Qwen3-14B

# --- Fireworks (cloud fallback for content_signal + report_writer) ---
FIREWORKS_KEY=

# --- Local-only mode (set to 1 to skip all Fireworks/remote calls) ---
LOCAL_ONLY=0
