# ------------------------------------------------------------
# Findable environment configuration
# Copy to `.env` and fill in the values:
#   cp .env.example .env
# ------------------------------------------------------------

# --- App / HTTP server (api service) ---
APP_NAME=Findable
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
LOG_LEVEL=info
CORS_ORIGINS=*

# --- Backend -> agents-api bridge ---
# In docker-compose this is overridden to http://agents-api:8080.
# Set to an empty string to disable /api/audit forwarding.
AGENTS_URL=http://localhost:8080

# --- Firecrawl (rendered crawl) ---
# Get a key at https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-your-key-here
FIRECRAWL_API_URL=https://api.firecrawl.dev
FIRECRAWL_API_VERSION=v2
FIRECRAWL_TIMEOUT=60

# --- Direct fetch (raw HTML, robots.txt, sitemap.xml, llms.txt) ---
FETCH_TIMEOUT=20
FETCH_USER_AGENT=FindableBot/0.1 (+https://findable.ai)

# --- Redis cache ---
# In docker-compose this is overridden to redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=604800

# --- Orchestrator scope ---
MAX_DEEP_PAGES=4
MAX_SHALLOW_PAGES=50

# --- Mock stream (dev / frontend testing) ---
# Set to true to bypass Firecrawl and agents entirely.
# Static SiteFacts + AuditReport are returned; real SSE events still stream
# on a realistic schedule. Zero API credits consumed.
MOCK_STREAM=false

# ------------------------------------------------------------
# Agents API / inference layer
# ------------------------------------------------------------

# Port the agents-api container exposes on the host.
API_PORT=8080

# --- Remote vLLM (AMD GPU server via cloudflared tunnels) ---
# Run vllm_hosting/start_service.sh on the GPU host. It prints these URLs.
# Priority: vLLM > Fireworks > Ollama. Backends are probed at startup.
# Leave blank to skip that tier; the router falls through automatically.
VLLM_URL=
VLLM_LIGHT_URL=
VLLM_HEAVY_MODEL_NAME=heavy
VLLM_LIGHT_MODEL_NAME=light

# --- Fireworks (Gemma cloud fallback when vLLM is unreachable) ---
# Official model paths:
#   Heavy: https://fireworks.ai/models/fireworks/gemma-4-26b-a4b-it
#   Light: https://fireworks.ai/models/fireworks/gemma-4-e4b
FIREWORKS_KEY=
FIREWORKS_HEAVY_MODEL=accounts/fireworks/models/gemma-4-26b-a4b-it
FIREWORKS_LIGHT_MODEL=accounts/fireworks/models/gemma-4-e4b

# --- Local Ollama (last-resort fallback) ---
# Docker uses host.docker.internal to reach Ollama on the host machine.
OLLAMA_URL=http://host.docker.internal:11434
LOCAL_LIGHT_MODEL=gemma4:e2b
LOCAL_HEAVY_MODEL=gemma4:e2b

# --- Token usage logging ---
# One JSON line per successful LLM call. Relative paths are resolved inside
# the agents-api container.
TOKEN_LOG_PATH=agents/logs/token_usage.jsonl

# --- Local-only mode ---
# Set to 1 to skip Fireworks entirely.
LOCAL_ONLY=0
