# ─────────────────────────────────────────────────────────────
# Findable — environment configuration
# Copy this file to `.env` and fill in the values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# --- App / HTTP server ---
APP_NAME=Findable
APP_HOST=0.0.0.0          # bind address (0.0.0.0 inside Docker)
APP_PORT=8000             # port the API listens on
APP_RELOAD=true           # auto-reload on code change (dev only)
LOG_LEVEL=info            # critical | error | warning | info | debug | trace

# Comma-separated allowed CORS origins, or "*" for all.
CORS_ORIGINS=*

# --- Firecrawl ---
# Get a key at https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-your-key-here
# Cloud default; point this at a self-hosted Firecrawl if you run one.
FIRECRAWL_API_URL=https://api.firecrawl.dev
# API version segment used in the request path: v2 (current) or v1.
FIRECRAWL_API_VERSION=v2
# Client-side timeout in seconds for the whole scrape request.
FIRECRAWL_TIMEOUT=60

# --- Redis cache ---
# Local dev default. In docker-compose this is overridden to redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0
# Toggle the cache off to always hit Firecrawl.
CACHE_ENABLED=true
# TTL for cached scrapes, in seconds. 0 = never expire (cache forever).
CACHE_TTL_SECONDS=604800

