# ─────────────────────────────────────────────────────────────
# Findable — environment configuration
# Copy to `.env` and fill in the values:   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# --- App / HTTP server ---
APP_NAME=Findable
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
LOG_LEVEL=info
CORS_ORIGINS=*

# --- Firecrawl (rendered crawl) ---
# Get a key at https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-your-key-here
FIRECRAWL_API_URL=https://api.firecrawl.dev
FIRECRAWL_API_VERSION=v2
FIRECRAWL_TIMEOUT=60

# --- Direct fetch (raw HTML, robots.txt, sitemap.xml, llms.txt) ---
FETCH_TIMEOUT=20
FETCH_USER_AGENT=FindableBot/0.1 (+https://findable.ai)

# --- Redis cache ---
# In docker-compose this is overridden to redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=604800          # 0 = never expire

# --- LLM / Model Router (scaffolded; off by default) ---
LLM_ENABLED=false
LLM_TIMEOUT=60
VLLM_BASE_URL=                    # e.g. http://vllm:8000/v1 (local vLLM on ROCm)
VLLM_API_KEY=EMPTY
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=

# --- Orchestrator scope (scaffolded) ---
MAX_DEEP_PAGES=4
MAX_SHALLOW_PAGES=50
